# Browser Settings
BROWSER_HEADLESS=false
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
BROWSER_ARGS=

# Context Settings
BROWSER_LOCALE=en-US
BROWSER_TIMEZONE=UTC
BROWSER_PERMISSIONS=
BROWSER_COLOR_SCHEME=light

# Timeouts (in milliseconds)
DEFAULT_TIMEOUT=30000
NAVIGATION_TIMEOUT=30000
PAGE_LOAD_CHECK_TIMEOUT=5000
NETWORK_IDLE_TIMEOUT=2000

# Screenshots
SCREENSHOT_DIRECTORY=~/.playwright-mcp-recording/screenshots
SCREENSHOT_TIMESTAMP_FORMAT=%Y%m%d_%H%M%S

# Stealth Mode
STEALTH_MODE=true

# Mobile Device Defaults
DEFAULT_MOBILE_DEVICE=iPhone 13

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# Video Recording
VIDEO_DIRECTORY=~/.playwright-mcp-recording/videos
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720